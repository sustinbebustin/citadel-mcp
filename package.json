{
  "name": "citadel-mcp",
  "version": "2.2.0",
  "description": "A growing Citadel of stack-specific docs, served as Codemode MCP tools for AI coding agents.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "citadel-mcp": "./dist/index.js"
  },
  "main": "dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sustinbebustin/citadel-mcp.git"
  },
  "mcpName": "io.github.sustinbebustin/citadel-mcp",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@cloudflare/codemode": "^0.2.2",
    "@modelcontextprotocol/sdk": "^1.25.0",
    "ai": "^6.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@vitest/coverage-v8": "^4.1.5",
    "prettier": "3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5"
  }
}
