{
  "name": "citadel-mcp",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "citadel-mcp": "./dist/index.js"
  },
  "main": "dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sustinbebustin/citadel-mcp.git"
  },
  "mcpName": "io.github.sustinbebustin/citadel-mcp",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.24.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "prettier": "3.3.3",
    "typescript": "^5.9.2"
  }
}
